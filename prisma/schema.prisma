generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INDIVIDUAL
  PRACTITIONER
}

enum Sex {
  MALE
  FEMALE
}

enum Season {
  WINTER
  SPRING
  SUMMER
  AUTUMN
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      Role      @default(INDIVIDUAL)
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  profiles  Profile[]
  patients  Patient[] @relation("PractitionerPatients")
}

model Profile {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  birthDate    DateTime
  sex          Sex
  heightCm     Float
  doshaType    String?
  ktScore      Float?
  relationship String       @default("self")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  bediRecords  BEDIRecord[]
  asPatient    Patient[]    @relation("PatientProfile")
}

model BEDIRecord {
  id             String          @id @default(cuid())
  profileId      String
  profile        Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date           DateTime        @default(now())
  weightKg       Float
  season         Season
  bedi           Float
  deviation      Float
  status         String
  notes          String?
  recommendation Recommendation?
}

model Recommendation {
  id           String     @id @default(cuid())
  bediRecordId String     @unique
  bediRecord   BEDIRecord @relation(fields: [bediRecordId], references: [id], onDelete: Cascade)
  remedies     String[]
  avoidFoods   String[]
  riskFactors  String[]
}

model Patient {
  id             String   @id @default(cuid())
  practitionerId String
  practitioner   User     @relation("PractitionerPatients", fields: [practitionerId], references: [id], onDelete: Cascade)
  profileId      String
  profile        Profile  @relation("PatientProfile", fields: [profileId], references: [id], onDelete: Cascade)
  clinicalNotes  String?
  addedAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
